{
  "name": "code-cast",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "../electron/main.js",
  "scripts": {
    "postinstall": "electron-rebuild -f -w node-pty",
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && NODE_ENV=development electron .\"",
    "electron:build": "vite build && electron-builder",
    "electron": "NODE_ENV=development electron ."
  },
  "dependencies": {
    "@monaco-editor/react": "^4.5.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "axios": "^1.6.7",
    "dexie": "^4.0.11",
    "diff": "^5.1.0",
    "js-cookie": "^3.0.5",
    "node-pty": "^1.2.0-beta.13",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^4.10.1",
    "react-router-dom": "^6.21.3",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.0.3",
    "concurrently": "^9.1.2",
    "electron": "^42.3.2",
    "electron-builder": "^26.8.1",
    "eslint": "^8.45.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "vite": "^4.4.5",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.codecast.app",
    "productName": "CodeCast",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "../electron/**/*"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
